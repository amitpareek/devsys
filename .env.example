# Copy this to .env (which is gitignored) and fill in.
#
#   cp .env.example .env
#   docker compose up -d

# ── Container 1 ───────────────────────────────────────────────────────
# Short tailnet name. Lowercase letters, numbers, hyphens.
HOST1=my-devbox

# Tailscale auth key (mark Reusable so restarts don't need a new key):
#   https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY1=tskey-auth-REPLACE-ME

# Where /root lives on the host. Leave unset to use a Docker named volume
# (managed, lives inside OrbStack's VM). Set to an absolute host path to
# bind-mount your Mac filesystem instead.
#DATA1=/Users/you/devsys-home-1


# ── Container 2 (only if you uncommented dev2 in compose.yml) ─────────
#HOST2=my-second-box
#TS_AUTHKEY2=tskey-auth-REPLACE-ME
#DATA2=/Users/you/devsys-home-2
